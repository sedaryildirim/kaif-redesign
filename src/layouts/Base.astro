---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '{ kaif } — Levantine Soul Food · Chaloklum Bay, Koh Phangan',
  description = 'Kaif is a beachside restaurant on Koh Phangan serving Levantine soul food made from scratch, daily. Fresh mezze, slow-cooked dishes, and handmade breads. Open 8AM–8PM, Chaloklum Bay.',
} = Astro.props;

const SITE = 'https://sedaryildirim.github.io/kaif-redesign';
const ogImage = `${SITE}/assets/kaif-hero-image.webp`;
const canonicalURL = `${SITE}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'Kaif',
  alternateName: '{ kaif }',
  description: 'Beachside Levantine restaurant in Chaloklum Bay, Koh Phangan. Soul food made from scratch: mezze, slow-cooked mains, handmade breads. Open daily 8AM–8PM.',
  url: canonicalURL,
  image: ogImage,
  servesCuisine: ['Levantine', 'Middle Eastern', 'Mediterranean'],
  priceRange: '$$',
  currenciesAccepted: 'THB',
  paymentAccepted: 'Cash, Credit Card',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '97/2 Moo 7',
    addressLocality: 'Ko Pha-ngan',
    addressRegion: 'Surat Thani',
    postalCode: '84280',
    addressCountry: 'TH',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 9.9476,
    longitude: 100.0394,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '08:00',
      closes: '20:00',
    },
  ],
  sameAs: [
    'https://www.instagram.com/kaifphangan',
    'https://www.facebook.com/kaifphangan',
  ],
  amenityFeature: [
    { '@type': 'LocationFeatureSpecification', name: 'Beachside seating', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Outdoor seating', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Vegetarian options', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Vegan options', value: true },
  ],
});
---

<!doctype html>
<html lang="en">
  <head>
    <script>document.documentElement.classList.add('js');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Kaif, Koh Phangan restaurant, Levantine food Thailand, Chaloklum Bay, Middle Eastern food Koh Phangan, beachside restaurant, mezze, soul food, halal-friendly, vegan options Koh Phangan" />
    <meta name="author" content="Kaif Restaurant" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="restaurant.restaurant" />
    <meta property="og:site_name" content="Kaif" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Kaif restaurant, Chaloklum Bay, Koh Phangan — beachside Levantine soul food" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Kaif restaurant, Chaloklum Bay, Koh Phangan" />

    <!-- Geo targeting -->
    <meta name="geo.region" content="TH-84" />
    <meta name="geo.placename" content="Chaloklum Bay, Ko Pha-ngan, Thailand" />
    <meta name="geo.position" content="9.9476;100.0394" />
    <meta name="ICBM" content="9.9476, 100.0394" />

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="theme-color" content="#f5f0e8" />
    <noscript><style>.hero-weather { display: none; }</style></noscript>

    <!-- Fonts: Alegreya (display) + Hanken Grotesk (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya:ital,wght@0,400;0,500;1,400;1,500&family=Hanken+Grotesk:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />

    <script>
      // Time-of-day hero eyebrow (Koh Phangan = UTC+7)
      const eyebrow = document.querySelector<HTMLElement>('.hero-eyebrow');
      const utc7Hour = (new Date().getUTCHours() + 7) % 24;
      if (eyebrow) {
        const dot = '·';
        if (utc7Hour >= 8 && utc7Hour < 20) {
          eyebrow.textContent = `Open now ${dot} Chaloklum Bay ${dot} Koh Phangan`;
        } else if (utc7Hour >= 5 && utc7Hour < 8) {
          eyebrow.textContent = `Opening at 8 AM ${dot} Chaloklum Bay ${dot} Koh Phangan`;
        }
      }

      // Time-of-day hero scrim warmth — amber in golden hour, cooler at bright midday
      const heroScrim = document.querySelector<HTMLElement>('.hero-scrim');
      if (heroScrim) {
        if (utc7Hour >= 16 && utc7Hour < 20) heroScrim.classList.add('hero-scrim--golden');
        else if (utc7Hour >= 10 && utc7Hour < 15) heroScrim.classList.add('hero-scrim--bright');
      }

      // Developer console easter egg
      console.log(
        '%c{ Kaif }',
        'font-family: Georgia, serif; font-size: 1.5rem; color: #4a8a8c; padding: 8px 0;'
      );
      console.log(
        '%cكَيف · Arabic: a state of pure bliss and deep pleasure.\nBeing exactly where you are meant to be.\n\nChaloklum Bay · Koh Phangan · Thailand\nOpen daily 8AM – 8PM',
        'color: #1e2d4a; font-style: italic; font-size: 0.875rem; line-height: 1.7;'
      );

      // Scroll reveal via IntersectionObserver
      const revealEls = document.querySelectorAll('[data-reveal]');
      if (revealEls.length) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delay = Number(el.dataset.delay ?? 0);
              setTimeout(() => el.classList.add('is-revealed'), delay);
              io.unobserve(el);
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // Nav / tide / back-to-top — single merged passive scroll handler
      const nav = document.querySelector<HTMLElement>('.site-nav');
      const tide = document.querySelector<HTMLElement>('.scroll-tide');
      const backToTop = document.querySelector<HTMLButtonElement>('#back-to-top');
      let tideTimer: ReturnType<typeof setTimeout>;
      let tideCompleted = false;

      const onScroll = () => {
        if (nav) nav.classList.toggle('site-nav--scrolled', window.scrollY > 48);
        if (tide) {
          const progress = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
          tide.style.width = `${Math.min(progress * 100, 100)}%`;
          tide.classList.add('is-visible');
          if (progress >= 0.97 && !tideCompleted) {
            tideCompleted = true;
            tide.classList.add('scroll-tide--complete');
            setTimeout(() => tide.classList.remove('scroll-tide--complete'), 1800);
          }
          clearTimeout(tideTimer);
          tideTimer = setTimeout(() => tide.classList.remove('is-visible'), 1400);
        }
        if (backToTop) {
          if (window.scrollY > 400) {
            backToTop.removeAttribute('hidden');
          } else {
            backToTop.setAttribute('hidden', '');
          }
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      if (backToTop) {
        backToTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // Nav active section indicator
      const navSections = document.querySelectorAll<HTMLElement>('section[id]');
      const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[href^="#"]');
      if (navSections.length && navLinks.length) {
        const sectionIO = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const id = (entry.target as HTMLElement).id;
              navLinks.forEach((a) => {
                a.classList.toggle('is-active', a.getAttribute('href') === `#${id}`);
              });
            });
          },
          { threshold: 0.35, rootMargin: '-10% 0px -45% 0px' }
        );
        navSections.forEach((s) => sectionIO.observe(s));
      }

      // Mobile nav toggle
      const navToggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
      if (navToggle && nav) {
        const closeNav = () => {
          nav.classList.remove('site-nav--open');
          navToggle.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
          navToggle.focus();
        };

        navToggle.addEventListener('click', () => {
          const isOpen = nav.classList.toggle('site-nav--open');
          navToggle.setAttribute('aria-expanded', String(isOpen));
          document.body.style.overflow = isOpen ? 'hidden' : '';
          if (isOpen) {
            const firstLink = nav.querySelector<HTMLAnchorElement>('.nav-links a');
            if (firstLink) firstLink.focus();
          }
        });

        nav.querySelectorAll('.nav-links a').forEach((link) => {
          link.addEventListener('click', closeNav);
        });

        // Escape closes nav
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && nav.classList.contains('site-nav--open')) closeNav();
        });

        // Focus trap — wraps Tab/Shift+Tab within open nav
        nav.addEventListener('keydown', (e) => {
          if (!nav.classList.contains('site-nav--open') || e.key !== 'Tab') return;
          const focusable = Array.from(
            nav.querySelectorAll<HTMLElement>('a,button:not([disabled]),[tabindex]:not([tabindex="-1"])')
          ).filter((el) => getComputedStyle(el).display !== 'none');
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey) {
            if (document.activeElement === first) { e.preventDefault(); last.focus(); }
          } else {
            if (document.activeElement === last) { e.preventDefault(); first.focus(); }
          }
        });
      }

      // Mobile menu scroll highlight — center-viewport item gets is-scroll-active
      {
        const mq = window.matchMedia('(max-width: 767px)');
        let scrollActiveItem: HTMLElement | null = null;

        const updateMenuHighlight = () => {
          if (!mq.matches) {
            if (scrollActiveItem) {
              scrollActiveItem.classList.remove('is-scroll-active');
              scrollActiveItem = null;
            }
            return;
          }
          const panel = document.querySelector<HTMLElement>('.menu-panel.is-active');
          const items = Array.from((panel ?? document).querySelectorAll<HTMLElement>('.menu-item'));
          if (!items.length) return;

          const midY = window.innerHeight / 2;
          let closest: HTMLElement | null = null;
          let closestDist = Infinity;

          items.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.height === 0) return;
            const dist = Math.abs(rect.top + rect.height / 2 - midY);
            if (dist < closestDist) { closestDist = dist; closest = el; }
          });

          if (closest !== scrollActiveItem) {
            if (scrollActiveItem) scrollActiveItem.classList.remove('is-scroll-active');
            if (closest) (closest as HTMLElement).classList.add('is-scroll-active');
            scrollActiveItem = closest;
          }
        };

        window.addEventListener('scroll', updateMenuHighlight, { passive: true });
        mq.addEventListener('change', updateMenuHighlight);

        // Re-run when tabs switch so highlight tracks the active panel
        document.addEventListener('click', (e) => {
          if ((e.target as HTMLElement)?.closest('.menu-tab')) {
            requestAnimationFrame(updateMenuHighlight);
          }
        });

        updateMenuHighlight();
      }

      // Easter egg: type "kaif" anywhere on the page to pulse the braces
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let seq = '';
        document.addEventListener('keydown', (e) => {
          const tag = (document.activeElement as HTMLElement)?.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
          seq += e.key.toLowerCase();
          if (seq.length > 4) seq = seq.slice(-4);
          if (seq === 'kaif') {
            seq = '';
            const braces = document.querySelectorAll<HTMLElement>('.logo-brace, .hero-brace');
            const restore = () => braces.forEach(b => b.style.removeProperty('color'));
            braces.forEach(b => { b.style.transition = 'color 0.35s ease'; b.style.color = 'var(--gold)'; });
            setTimeout(() => { braces.forEach(b => b.style.color = 'var(--seafoam)'); }, 380);
            setTimeout(() => { restore(); braces.forEach(b => b.style.removeProperty('transition')); }, 760);
          }
        });
      }

      // Click ripple
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.addEventListener('click', (e) => {
          const ripple = document.createElement('div');
          ripple.className = 'click-ripple';
          ripple.style.left = `${e.clientX}px`;
          ripple.style.top  = `${e.clientY}px`;
          document.body.appendChild(ripple);
          setTimeout(() => ripple.remove(), 750);
        });
      }

      // Live weather — Chaloklum Bay, Koh Phangan via Open-Meteo (no API key)
      {
        const weatherEl = document.querySelector<HTMLElement>('.hero-weather');
        if (weatherEl) {
          const WX_TYPE: Record<number, string> = {
            0: '', 1: '', 2: 'cloud', 3: 'cloud', 45: 'fog', 48: 'fog',
            51: 'rain', 53: 'rain', 55: 'rain', 61: 'rain', 63: 'rain', 65: 'rain',
            80: 'rain', 81: 'rain', 82: 'rain', 95: 'storm', 96: 'storm', 99: 'storm',
          };

          function wxSentence(temp: number, code: number, h24: number, dt: string, display: string): string {
            const t    = `<time datetime="${dt}">${display}</time>`;
            const hot  = temp >= 30;
            const warm = temp >= 26;
            const deg  = hot ? `a blazing ${temp}°` : warm ? `a warm ${temp}°` : `${temp}°`;
            const morn = h24 >= 8  && h24 < 12;
            const noon = h24 >= 12 && h24 < 14;
            const aft  = h24 >= 14 && h24 < 18;
            const gold = h24 >= 18 && h24 < 20;

            if (code <= 1) {
              if (morn) return `${t} · ${deg} and clear. A fine morning to eat by the water.`;
              if (noon) return `${t} · ${deg} and full sun. The terrace is yours.`;
              if (aft)  return `${t} · ${deg} and open skies. Come sit outside.`;
              if (gold) return `${t} · ${deg} and golden over the water. Last seats today.`;
              return `${t} · ${deg} and clear over Chaloklum Bay.`;
            }
            if (code === 2) {
              if (morn) return `${t} · ${deg} with soft cloud. A gentle morning on the bay.`;
              if (aft || noon) return `${t} · ${deg} and partly cloudy. Good shade for a long lunch.`;
              return `${t} · ${deg} and partly cloudy over the bay.`;
            }
            if (code === 3) {
              return `${t} · ${deg} and overcast. Made for eating slowly.`;
            }
            if (code >= 45 && code <= 48) {
              return `${t} · ${deg} and misty on the bay. The kitchen is warm.`;
            }
            if (code >= 51 && code <= 67) {
              return `${t} · ${deg} and raining. Come in, we're open.`;
            }
            if (code >= 80 && code <= 82) {
              return `${t} · ${deg} with passing showers. Warm inside, we're open.`;
            }
            if (code >= 95) {
              return `${t} · ${deg} and stormy. Good shelter, good food.`;
            }
            return `${t} · ${deg} at Chaloklum Bay.`;
          }

          fetch('https://api.open-meteo.com/v1/forecast?latitude=9.9476&longitude=100.0394&current=temperature_2m,weather_code&timezone=Asia%2FBangkok')
            .then((r) => r.ok ? r.json() : Promise.reject())
            .then((d) => {
              const temp = Math.round(d.current.temperature_2m);
              const code = Number(d.current.weather_code);
              const wx   = WX_TYPE[code] ?? '';
              if (wx) weatherEl.setAttribute('data-wx', wx);
              weatherEl.classList.add('is-loaded');

              const render = () => {
                const now = new Date();
                const h24 = (now.getUTCHours() + 7) % 24;
                const min = now.getUTCMinutes();
                const h12 = h24 % 12 || 12;
                const mm  = String(min).padStart(2, '0');
                const ap  = h24 >= 12 ? 'PM' : 'AM';
                weatherEl.innerHTML = wxSentence(temp, code, h24,
                  `${String(h24).padStart(2, '0')}:${mm}`,
                  `${h12}:${mm} ${ap}`
                );
              };
              render();
              setInterval(render, 30_000);
            })
            .catch(() => {});
        }
      }
    </script>
  </body>
</html>
