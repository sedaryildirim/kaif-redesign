  <!-- ================================================================
       GSAP: hero entry + scroll parallax
       ================================================================ -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const isMobile = window.matchMedia('(max-width: 960px)').matches;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Hero cursor glow ─────────────────────────────────────────────
    if (!isMobile && !prefersReducedMotion) {
      const heroEl   = document.querySelector<HTMLElement>('.hero');
      const heroGlow = document.querySelector<HTMLElement>('.hero-cursor-glow');
      if (heroEl && heroGlow) {
        heroEl.addEventListener('mousemove', (e) => {
          const rect = heroEl.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          heroGlow.style.background = `radial-gradient(circle 500px at ${x}px ${y}px, oklch(58% 0.11 75 / 0.12), oklch(72% 0.05 185 / 0.04) 55%, transparent 75%)`;
          heroGlow.classList.add('is-active');
        }, { passive: true });
        heroEl.addEventListener('mouseleave', () => heroGlow.classList.remove('is-active'));
      }
    }

    // ── Scroll parallax — skipped if user prefers reduced motion ────
    if (!prefersReducedMotion) {
      const heroImg = document.querySelector<HTMLElement>('.hero-img');
      if (heroImg && !isMobile) {
        heroImg.style.willChange = 'transform';
        gsap.fromTo(heroImg,
          { yPercent: -4 },
          {
            yPercent: 4,
            ease: 'none',
            scrollTrigger: {
              trigger: '.hero',
              start: 'top top',
              end: 'bottom top',
              scrub: 1.5,
            },
          }
        );
      }

      const placeImg = document.querySelector<HTMLElement>('.place-img-wrap img');
      if (placeImg && !isMobile) {
        placeImg.style.willChange = 'transform';
        gsap.fromTo(placeImg,
          { yPercent: -3 },
          {
            yPercent: 3,
            ease: 'none',
            scrollTrigger: {
              trigger: '.section-place',
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.5,
            },
          }
        );
      }

      // ── Hero content exit — text clips from bottom as user scrolls past ──────
      if (!isMobile) {
        const heroContent = document.querySelector<HTMLElement>('.hero-content');
        if (heroContent) {
          heroContent.style.willChange = 'clip-path';
          gsap.set(heroContent, { clipPath: 'inset(0% 0% 0% 0%)' });
          gsap.to(heroContent, {
            clipPath: 'inset(0% 0% 100% 0%)',
            ease: 'none',
            scrollTrigger: {
              trigger: '.hero',
              start: 'center top',
              end: 'bottom top',
              scrub: 0.5,
            },
          });
        }
      }

      // ── About — simultaneous split clip reveal (image left, text right) ──────
      if (!isMobile) {
        const placeImgWrap  = document.querySelector<HTMLElement>('.place-img-wrap');
        const placeTextWrap = document.querySelector<HTMLElement>('.place-text');
        if (placeImgWrap && placeTextWrap) {
          placeImgWrap.style.willChange  = 'clip-path';
          placeTextWrap.style.willChange = 'clip-path';
          gsap.set(placeImgWrap,  { clipPath: 'inset(0 100% 0 0)' });
          gsap.set(placeTextWrap, { clipPath: 'inset(0 0 0 100%)' });

          const splitRevealTl = gsap.timeline({
            scrollTrigger: { trigger: '.place-inner', start: 'top 88%' },
            onComplete: () => {
              placeImgWrap.style.removeProperty('will-change');
              placeTextWrap.style.removeProperty('will-change');
            },
          });
          splitRevealTl
            .to(placeImgWrap,  { clipPath: 'inset(0 0% 0 0)',  duration: 1.4, ease: 'expo.out' })
            .to(placeTextWrap, { clipPath: 'inset(0 0 0 0%)',  duration: 1.4, ease: 'expo.out' }, '<0.12');
        }
      }

      // ── Kinetic heading character stagger ─────────────────────────────────────
      if (!isMobile) {
        const kineticTargets: Array<{ sel: string; start: string; delay: number }> = [
          { sel: '#place-heading',     start: 'top 75%', delay: 0.65 },
          { sel: '#menu-heading',      start: 'top 78%', delay: 0    },
          { sel: '.menu-card-body h3', start: 'top 80%', delay: 0    },
          { sel: '#full-menu-heading', start: 'top 78%', delay: 0    },
          { sel: '.reviews-heading',   start: 'top 78%', delay: 0    },
          { sel: '#findus-heading',    start: 'top 78%', delay: 0    },
        ];

        kineticTargets.forEach(({ sel, start, delay }) => {
          document.querySelectorAll<HTMLElement>(sel).forEach((heading) => {
            const text = heading.textContent ?? '';
            heading.setAttribute('aria-label', text);
            // Wrap each word in white-space:nowrap so inline-block chars can't break mid-word
            heading.innerHTML = text.split(' ').map(word =>
              `<span style="display:inline-block;white-space:nowrap">${[...word].map(char =>
                `<span aria-hidden="true" class="char-k" style="display:inline-block">${char}</span>`
              ).join('')}</span>`
            ).join('<span aria-hidden="true" style="display:inline-block" class="char-k">&nbsp;</span>');

            gsap.from(heading.querySelectorAll<HTMLElement>('.char-k'), {
              opacity: 0,
              y: 18,
              duration: 0.75,
              ease: 'expo.out',
              stagger: 0.038,
              delay,
              scrollTrigger: { trigger: heading, start },
            });
          });
        });
      }
    }
  </script>

  <script>
    // Tab switching — full menu section
    const menuTabs = document.querySelectorAll<HTMLButtonElement>('.menu-tab');
    const menuPanels = document.querySelectorAll<HTMLElement>('.menu-panel');

    const activateTab = (tab: HTMLButtonElement) => {
      const target = tab.dataset.target;
      menuTabs.forEach((t) => {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      menuPanels.forEach((p) => p.classList.remove('is-active'));
      const panel = document.getElementById(`tab-${target}`);
      if (panel) {
        panel.classList.add('is-active');
        // Stagger-reveal items that haven't been revealed by scroll yet
        panel.querySelectorAll<HTMLElement>('.menu-item[data-reveal]').forEach((item, i) => {
          if (!item.classList.contains('is-revealed')) {
            setTimeout(() => item.classList.add('is-revealed'), i * 55);
          }
        });
      }
    };

    // Mobile scroll highlight — triggers hover effect as items enter viewport
    if (window.matchMedia('(max-width: 960px)').matches &&
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const scrollHighlightIO = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const item = entry.target as HTMLElement;
            item.classList.add('is-scroll-active');
            setTimeout(() => item.classList.remove('is-scroll-active'), 1100);
          });
        },
        { threshold: 0.4, rootMargin: '0px 0px -60px 0px' }
      );
      document.querySelectorAll('.menu-item').forEach((item) => scrollHighlightIO.observe(item));
    }

    menuTabs.forEach((tab, idx) => {
      tab.addEventListener('click', () => activateTab(tab));

      tab.addEventListener('keydown', (e) => {
        const count = menuTabs.length;
        let next = -1;
        if (e.key === 'ArrowRight') next = (idx + 1) % count;
        if (e.key === 'ArrowLeft')  next = (idx - 1 + count) % count;
        if (e.key === 'Home')       next = 0;
        if (e.key === 'End')        next = count - 1;
        if (next >= 0) {
          e.preventDefault();
          (menuTabs[next] as HTMLButtonElement).focus();
          activateTab(menuTabs[next] as HTMLButtonElement);
        }
      });
    });
  </script>

  <!-- Legal modal JS -->
  <script>
    const modals = document.querySelectorAll<HTMLElement>('.legal-modal');

    const getFocusable = (el: HTMLElement) =>
      Array.from(el.querySelectorAll<HTMLElement>(
        'a[href],button:not([disabled]),textarea,input,select,[tabindex]:not([tabindex="-1"])'
      ));

    const openModal = (id: string) => {
      const modal = document.getElementById(`modal-${id}`);
      if (!modal) return;
      modal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      const panel = modal.querySelector<HTMLElement>('.legal-modal-panel');
      if (panel) panel.scrollTop = 0;
      const close = modal.querySelector<HTMLElement>('.legal-modal-close');
      if (close) close.focus();
    };

    const closeModal = (modal: HTMLElement) => {
      modal.setAttribute('hidden', '');
      document.body.style.overflow = '';
    };

    document.querySelectorAll<HTMLButtonElement>('.footer-legal-btn').forEach((btn) => {
      btn.addEventListener('click', () => openModal(btn.dataset.modal ?? ''));
    });

    modals.forEach((modal) => {
      modal.querySelector('.legal-modal-close')?.addEventListener('click', () => closeModal(modal));
      modal.querySelector('.legal-modal-backdrop')?.addEventListener('click', () => closeModal(modal));
      modal.addEventListener('keydown', (e) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Escape') { closeModal(modal); return; }
        if (ke.key !== 'Tab') return;
        const focusable = getFocusable(modal);
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (ke.shiftKey && document.activeElement === first) {
          e.preventDefault(); last.focus();
        } else if (!ke.shiftKey && document.activeElement === last) {
          e.preventDefault(); first.focus();
        }
      });
    });
  </script>

