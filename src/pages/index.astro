---
import Base from '../layouts/Base.astro';

/*
 * Image note: all photography uses picsum.photos placeholders.
 * Place real Kaif photography in public/assets/images/ and update src attributes.
 * Each placeholder uses a seed for consistent builds.
 */
---

<Base>
  <div class="scroll-tide" aria-hidden="true"></div>

  <!-- ================================================================
       NAVIGATION
       ================================================================ -->
  <header class="site-nav">
    <nav class="nav-inner" aria-label="Main navigation">
      <a class="nav-logo" href="/" aria-label="{ kaif } — home">
        <span class="logo-brace">&#123;</span>&thinsp;kaif&thinsp;<span class="logo-brace">&#125;</span>
      </a>
      <ul class="nav-links" id="nav-links-list" role="list">
        <li><a href="#about">About</a></li>
        <li><a href="#menu">Menu</a></li>
        <li><a href="#visit">Find Us</a></li>
        <li><a href="#visit">Contact</a></li>
      </ul>
      <a
        class="btn btn-primary btn-nav"
        href="https://delivery-kpg.com/stores/kaif"
        target="_blank"
        rel="noopener noreferrer"
      >
        Order
      </a>
      <button
        class="nav-toggle"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="nav-links-list"
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </nav>
  </header>

  <main id="main-content">
    <!-- ================================================================
         HERO — full-bleed image with centered text overlay
         ================================================================ -->
    <section class="hero" aria-label="Welcome to Kaif">

      <!-- Full-bleed background image -->
      <div class="hero-img-wrap" aria-hidden="true">
        <img
          class="hero-img"
          src="/assets/kaif-hero-image.jpg"
          alt=""
          width="1600"
          height="900"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="hero-scrim" aria-hidden="true"></div>

      <!-- Centered text content -->
      <div class="hero-content">
        <span class="hero-eyebrow">Chaloklum Bay &middot; Koh Phangan</span>

        <h1 class="hero-wordmark" aria-label="{ kaif }">
          <span class="hero-brace" aria-hidden="true">&#123;</span>&thinsp;<em>kaif</em>&thinsp;<span class="hero-brace" aria-hidden="true">&#125;</span>
        </h1>

        <p class="hero-tagline">
          Levantine soul food, made from scratch,<br />at the edge of the water.
        </p>

        <div class="hero-ctas">
          <a class="btn btn-primary-light" href="#menu">The Menu</a>
          <a
            class="btn btn-ghost-light"
            href="https://delivery-kpg.com/stores/kaif"
            target="_blank"
            rel="noopener noreferrer"
          >Order Online</a>
        </div>

        <p class="hero-meta">Open daily &middot; 8:00 AM &ndash; 8:00 PM</p>
      </div>

    </section>

    <!-- ================================================================
         FACT STRIP
         ================================================================ -->
    <section class="fact-strip" aria-label="Kaif at a glance">
      <div class="fact-strip-inner">
        <div class="fact-item" data-reveal data-delay="0">
          <span class="fact-value">8AM &ndash; 8PM</span>
          <span class="fact-desc">Open every day</span>
        </div>
        <div class="fact-divider" role="separator" aria-hidden="true"></div>
        <div class="fact-item" data-reveal data-delay="100">
          <span class="fact-value">Made from scratch</span>
          <span class="fact-desc">Every dish, every morning</span>
        </div>
        <div class="fact-divider" role="separator" aria-hidden="true"></div>
        <div class="fact-item fact-item--place" data-reveal data-delay="200">
          <span class="fact-value">Chaloklum Bay</span>
          <span class="fact-desc">At the edge of the water</span>
        </div>
      </div>
    </section>

    <!-- ================================================================
         ABOUT
         ================================================================ -->
    <section class="section-place" id="about" aria-labelledby="place-heading">
      <div class="place-inner">
        <div class="place-img-wrap" data-reveal="fade">
          <img
            src="/assets/kaif-interior-shot.jpg"
            alt="Kaif interior — warm light, tables by the water on Chaloklum Bay"
            width="1600"
            height="900"
            loading="lazy"
          />
        </div>
        <div class="place-text" data-reveal data-delay="80">
          <h2 id="place-heading">A seat at the edge of the bay.</h2>
          <p>
            White umbrellas, the Chaloklum pier to your right, water in every
            direction. &#123; kaif &#125; sits directly on the shore of one of Koh Phangan's
            quietest bays. Breakfast here becomes an event. Lunch, a reason to stay.
          </p>
          <p data-reveal data-delay="160">
            Levantine soul food meets tropical paradise. Every dish made from
            scratch, every day. The laffa kneaded and baked each morning. The
            cold brew aged on-site. The hummus, the carrot cake, the bread:
            nothing arrives in a box.
          </p>
          <p data-reveal data-delay="240">
            Seven days a week, eight to eight. Come for breakfast. Stay for
            everything.
          </p>
        </div>
      </div>
    </section>

    <!-- ================================================================
         MENU
         ================================================================ -->
    <section class="section-menu" id="menu" aria-labelledby="menu-heading">
      <div class="wrap">
        <div class="menu-header" data-reveal>
          <h2 id="menu-heading">From the Menu</h2>
        </div>

        <div class="menu-cards">
          <article class="menu-card menu-card--wide" data-reveal data-delay="0" aria-label="Shakshuka">
            <div class="menu-card-img">
              <img
                src="/assets/kaif-interior-shot.jpg"
                alt="Shakshuka: eggs in spiced tomato with homemade folded laffa"
                width="900" height="720" loading="lazy"
                style="object-position: center 20%;"
              />
            </div>
            <div class="menu-card-body">
              <span class="label">Breakfast</span>
              <h3>Shakshuka</h3>
              <p>Eggs poached in spiced tomato, sweet peppers, and herbs. With homemade laffa, baked fresh each morning.</p>
            </div>
          </article>

          <article class="menu-card" data-reveal data-delay="80" aria-label="Levant Breakfast">
            <div class="menu-card-img">
              <img
                src="/assets/kaif-hero-image.jpg"
                alt="Levant Breakfast: hummus, Israeli salad, labneh, olives, and fresh laffa"
                width="900" height="720" loading="lazy"
                style="object-position: center 55%;"
              />
            </div>
            <div class="menu-card-body">
              <span class="label">All Day</span>
              <h3>Levant Breakfast</h3>
              <p>House hummus, Israeli salad, labneh, olives, soft-boiled egg, and fresh laffa.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ================================================================
         FULL MENU — tabbed
         ================================================================ -->
    <section class="section-full-menu" aria-labelledby="full-menu-heading">
      <div class="wrap">
        <div class="menu-full-header" data-reveal>
          <span class="label">Full Menu</span>
          <h2 id="full-menu-heading">Everything from the Kitchen</h2>
        </div>

        <nav class="menu-tabs" role="tablist" aria-label="Menu categories">
          <button class="menu-tab is-active" role="tab" aria-selected="true"
            aria-controls="tab-breakfast" id="btn-breakfast" data-target="breakfast">Breakfast</button>
          <button class="menu-tab" role="tab" aria-selected="false"
            aria-controls="tab-all-day" id="btn-all-day" data-target="all-day">All Day</button>
          <button class="menu-tab" role="tab" aria-selected="false"
            aria-controls="tab-drinks" id="btn-drinks" data-target="drinks">Drinks</button>
          <button class="menu-tab" role="tab" aria-selected="false"
            aria-controls="tab-coffees" id="btn-coffees" data-target="coffees">Coffees</button>
        </nav>

        <div class="menu-panels">

          <!-- Breakfast -->
          <div class="menu-panel is-active" id="tab-breakfast" role="tabpanel" aria-labelledby="btn-breakfast">
            <ul class="menu-list" role="list">
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Toasted Sourdough</h3>
                  <span class="menu-item-price">฿90</span>
                </div>
                <p class="menu-item-desc">Butter or labneh, house-baked daily.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Eggs Your Way</h3>
                  <span class="menu-item-price">฿130</span>
                </div>
                <p class="menu-item-desc">Scrambled, fried, or poached. Two eggs, warm laffa.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">&#123; kaif &#125; Breakfast</h3>
                  <span class="menu-item-price">฿340</span>
                </div>
                <p class="menu-item-desc">Eggs your way, shakshuka, hummus, labneh, Israeli salad, olives, cheese, and fresh laffa.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Veggie Breakfast</h3>
                  <span class="menu-item-price">฿320</span>
                </div>
                <p class="menu-item-desc">Shakshuka, hummus, labneh, Israeli salad, olives, cheese, and warm laffa.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Salmon Brioche</h3>
                  <span class="menu-item-price">฿270</span>
                </div>
                <p class="menu-item-desc">Smoked salmon, labneh, capers, red onion on toasted brioche.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Eggs Benedict &amp; Royale</h3>
                  <span class="menu-item-price">฿280</span>
                </div>
                <p class="menu-item-desc">Poached eggs, hollandaise on sourdough. Benedict with ham; Royale with smoked salmon.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Loaded Sourdough Toasts</h3>
                  <span class="menu-item-price">฿260</span>
                </div>
                <p class="menu-item-desc">Smashed avocado, feta, sun-dried tomatoes, za&rsquo;atar, and poached egg.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Salmon Rosti</h3>
                  <span class="menu-item-price">฿300</span>
                </div>
                <p class="menu-item-desc">Crispy potato rosti, smoked salmon, poached egg, crème fra&icirc;che, capers.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Shakshuka</h3>
                  <span class="menu-item-price">฿290</span>
                </div>
                <p class="menu-item-desc">Eggs poached in spiced tomato with sweet peppers and herbs. Warm laffa alongside.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Levant Breakfast</h3>
                  <span class="menu-item-price">฿340</span>
                </div>
                <p class="menu-item-desc">Hummus, Israeli salad, labneh, olives, soft-boiled egg, and fresh laffa.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">&#123; kaif &#125; Granola</h3>
                  <span class="menu-item-price">฿250</span>
                </div>
                <p class="menu-item-desc">House granola, natural yogurt, seasonal fruit, local honey.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Banana French Toast</h3>
                  <span class="menu-item-price">฿290</span>
                </div>
                <p class="menu-item-desc">Thick brioche, caramelised banana, maple syrup, labneh cream.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Aca&iacute; Smoothie Bowl</h3>
                  <span class="menu-item-price">฿260</span>
                </div>
                <p class="menu-item-desc">Aca&iacute; base, banana, granola, coconut flakes, seasonal fruit.</p>
              </li>
            </ul>
          </div>

          <!-- All Day -->
          <div class="menu-panel" id="tab-all-day" role="tabpanel" aria-labelledby="btn-all-day">
            <ul class="menu-list" role="list">
              <li class="menu-category-label" role="presentation">Salads &amp; Bowls</li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Israeli Salad</h3>
                  <span class="menu-item-price">฿150</span>
                </div>
                <p class="menu-item-desc">Finely diced cucumber, tomato, herbs, olive oil, lemon.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Fatoush</h3>
                  <span class="menu-item-price">฿180</span>
                </div>
                <p class="menu-item-desc">Toasted laffa croutons, seasonal vegetables, sumac dressing.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Goat Cheese &amp; Beetroot</h3>
                  <span class="menu-item-price">฿320</span>
                </div>
                <p class="menu-item-desc">Roasted beetroot, creamy goat cheese, walnuts, rocket, balsamic glaze.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Caesar</h3>
                  <span class="menu-item-price">฿240</span>
                </div>
                <p class="menu-item-desc">Cos lettuce, parmesan, house Caesar dressing, sourdough croutons.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Superfood</h3>
                  <span class="menu-item-price">฿320</span>
                </div>
                <p class="menu-item-desc">Quinoa, roasted sweet potato, avocado, edamame, tahini dressing.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Pok&eacute; Bowl</h3>
                  <span class="menu-item-price">from ฿320</span>
                </div>
                <p class="menu-item-desc">Rice base with fresh toppings. Ask your server for today&rsquo;s selection.</p>
              </li>
              <li class="menu-category-label" role="presentation">Plates, Wraps &amp; Burgers</li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Hummus Bowl</h3>
                  <span class="menu-item-price">฿240</span>
                </div>
                <p class="menu-item-desc">Slow-cooked house hummus, olive oil, za&rsquo;atar, warm laffa.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">&#123; kaif &#125; Plate</h3>
                  <span class="menu-item-price">฿220</span>
                </div>
                <p class="menu-item-desc">Hummus, labneh, Israeli salad, olives, cheese, and laffa.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">&#123; kaif &#125; Burger</h3>
                  <span class="menu-item-price">฿450</span>
                </div>
                <p class="menu-item-desc">Beef patty, cheddar, caramelised onion, house sauce, brioche bun. Served with fries.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Korean Fried Chicken Burger</h3>
                  <span class="menu-item-price">฿360</span>
                </div>
                <p class="menu-item-desc">Crispy chicken, gochujang mayo, slaw, pickled cucumber, brioche bun. With fries.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Laffa Wraps</h3>
                  <span class="menu-item-price">from ฿280</span>
                </div>
                <p class="menu-item-desc">Choose your filling: falafel, chicken shawarma, or halloumi. With tahini and salad.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Focaccia Sandwiches</h3>
                  <span class="menu-item-price">฿290</span>
                </div>
                <p class="menu-item-desc">House focaccia with daily-changing fillings. Ask your server.</p>
              </li>
              <li class="menu-category-label" role="presentation">Sides</li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Homemade Fries</h3>
                  <span class="menu-item-price">฿140</span>
                </div>
                <p class="menu-item-desc">Hand-cut, seasoned with sea salt and herbs.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Truffle Parmesan Fries</h3>
                  <span class="menu-item-price">฿190</span>
                </div>
                <p class="menu-item-desc">Fries tossed with truffle oil and shaved parmesan.</p>
              </li>
            </ul>
          </div>

          <!-- Drinks -->
          <div class="menu-panel" id="tab-drinks" role="tabpanel" aria-labelledby="btn-drinks">
            <ul class="menu-list" role="list">
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Tea Pots</h3>
                  <span class="menu-item-price">฿120</span>
                </div>
                <p class="menu-item-desc">Rotating selection of whole-leaf teas. Ask your server.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Fresh Coconut</h3>
                  <span class="menu-item-price">฿120</span>
                </div>
                <p class="menu-item-desc">Young coconut, served straight from the husk with a straw.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Iced Tea</h3>
                  <span class="menu-item-price">฿90</span>
                </div>
                <p class="menu-item-desc">House-brewed, lightly sweetened. Classic or hibiscus.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Fresh Squeezed Juices</h3>
                  <span class="menu-item-price">฿140</span>
                </div>
                <p class="menu-item-desc">Orange, watermelon, or grapefruit. Pressed to order.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Mixed Fresh Juices</h3>
                  <span class="menu-item-price">฿160</span>
                </div>
                <p class="menu-item-desc">Seasonal blends: ask your server what&rsquo;s pressing today.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Fresh Fruit Shakes</h3>
                  <span class="menu-item-price">฿120</span>
                </div>
                <p class="menu-item-desc">Blended with ice and a splash of coconut milk. Mango, banana, or mixed.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Water &amp; Soda</h3>
                  <span class="menu-item-price">฿30&ndash;50</span>
                </div>
                <p class="menu-item-desc">Still or sparkling water, Coke, and soft drinks.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Beer</h3>
                  <span class="menu-item-price">฿90</span>
                </div>
                <p class="menu-item-desc">Chang or Singha. Ice cold.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">House Wine</h3>
                  <span class="menu-item-price">฿180 / ฿990</span>
                </div>
                <p class="menu-item-desc">Red or white. Glass or bottle.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Sparkling Wine</h3>
                  <span class="menu-item-price">฿220 / ฿1,050</span>
                </div>
                <p class="menu-item-desc">Glass or bottle. Ask your server for selection.</p>
              </li>
            </ul>
          </div>

          <!-- Coffees -->
          <div class="menu-panel" id="tab-coffees" role="tabpanel" aria-labelledby="btn-coffees">
            <ul class="menu-list" role="list">
              <li class="menu-category-label" role="presentation">Blacks</li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Espresso / Americano / Long Black / Filter</h3>
                  <span class="menu-item-price">฿80</span>
                </div>
                <p class="menu-item-desc">House-blend espresso, or rotating single-origin filter.</p>
              </li>
              <li class="menu-category-label" role="presentation">Whites</li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Cappuccino / Flat White / Latte / Macchiato</h3>
                  <span class="menu-item-price">฿100</span>
                </div>
                <p class="menu-item-desc">Espresso with steamed milk. Oat milk available on request.</p>
              </li>
              <li class="menu-category-label" role="presentation">Specialty</li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Matcha Latte</h3>
                  <span class="menu-item-price">฿120</span>
                </div>
                <p class="menu-item-desc">Ceremonial-grade matcha, steamed milk. Hot or iced.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Frapp&eacute;</h3>
                  <span class="menu-item-price">฿120</span>
                </div>
                <p class="menu-item-desc">Blended iced coffee, creamy and cold.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Cold Brew: Rum &amp; Raisin</h3>
                  <span class="menu-item-price">฿150</span>
                </div>
                <p class="menu-item-desc">Slow-brewed in-house. Deep, barrel-rounded, served over ice.</p>
              </li>
              <li class="menu-item">
                <div class="menu-item-header">
                  <h3 class="menu-item-name">Cold Brew: Peach &amp; Lychee</h3>
                  <span class="menu-item-price">฿150</span>
                </div>
                <p class="menu-item-desc">Bright and floral. Slow-brewed, served over ice.</p>
              </li>
              <li class="menu-extras-note" role="presentation">Extras: alternative milks (oat, almond, soy) +฿30 &nbsp;&middot;&nbsp; extra shot +฿30 &nbsp;&middot;&nbsp; syrup +฿20</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ================================================================
         REVIEWS
         ================================================================ -->
    <section class="section-reviews" aria-labelledby="reviews-heading">
      <div class="wrap">
        <div class="reviews-header" data-reveal>
          <h2 id="reviews-heading" class="reviews-heading">What people say.</h2>
        </div>
        <div class="reviews-grid">

          <blockquote class="review" data-reveal data-delay="0">
            <span class="review-mark" aria-hidden="true">&ldquo;</span>
            <p class="review-text">Breakfast at &#123; kaif &#125; became a ritual. The laffa, warm and folded, made that morning, is the kind of thing you don&rsquo;t find twice.</p>
