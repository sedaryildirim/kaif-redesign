{"nodes": [{"id": "product_md_kaif", "label": "Kaif Product Document", "file_type": "document", "source_file": "PRODUCT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "product_md_brandidentity", "label": "Kaif Brand Identity (Levantine soul food, beach bar, Koh Phangan)", "file_type": "concept", "source_file": "PRODUCT.md", "source_location": "line 1-19", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Kaif is a beachside restaurant on Chaloklum Bay, Koh Phangan. The name is Arabic for pure bliss and being exactly where you are meant to be. The product purpose is to make visitors feel the place before they arrive \u2014 success measured by orders, location saves, or brand recall."}, {"id": "product_md_menuidentity", "label": "Kaif Menu Identity (Breakfast, All Day, Drinks)", "file_type": "concept", "source_file": "PRODUCT.md", "source_location": "line 22-29", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "product_md_brandpersonality", "label": "Brand Personality: Warm, Elevated, Unhurried", "file_type": "rationale", "source_file": "PRODUCT.md", "source_location": "line 31-35", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Luxury redefined as ease and intention rather than expense or formality. Guest reviews confirm: gorgeous, airy, peaceful, warm, genuinely attentive."}, {"id": "product_md_antireferences", "label": "Anti-References (design anti-patterns to avoid)", "file_type": "rationale", "source_file": "PRODUCT.md", "source_location": "line 42-47", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Explicitly avoid: generic tropical cliche (sunset gradients, palm-tree clip art), budget beach shack aesthetic, corporate hospitality (stock photography, sterile white, CTA-heavy templates), Instagram-filter saturation."}, {"id": "product_md_designprinciples", "label": "Kaif Design Principles (6 principles)", "file_type": "rationale", "source_file": "PRODUCT.md", "source_location": "line 48-56", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "1) Place before product \u2014 atmosphere palpable via typography, color, space. 2) Warmth with precision \u2014 approachable but never sloppy. 3) Color as character \u2014 strategic color splashes with emotional weight. 4) Editorial confidence \u2014 headlines assume interest. 5) Unhurried pace \u2014 generous spacing, measured motion. 6) Levantine soul \u2014 Laffa, shakshuka, hummus present in design language."}, {"id": "concept_kaif_arabic_meaning", "label": "Kaif (Arabic): State of pure bliss, being exactly where you are meant to be", "file_type": "concept", "source_file": "PRODUCT.md", "source_location": "line 8-9", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_levantine_soulfood", "label": "Levantine Soul Food Identity (laffa, shakshuka, hummus, falafel)", "file_type": "concept", "source_file": "PRODUCT.md", "source_location": "line 22-29", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_chaloklum_bay", "label": "Chaloklum Bay Location (Koh Phangan, Thailand)", "file_type": "concept", "source_file": "PRODUCT.md", "source_location": "line 16-19", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "product_md_kaif", "target": "product_md_brandidentity", "relation": "defines", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PRODUCT.md", "source_location": "line 1-19", "weight": 1.0}, {"source": "product_md_kaif", "target": "product_md_menuidentity", "relation": "defines", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PRODUCT.md", "source_location": "line 22-29", "weight": 1.0}, {"source": "product_md_kaif", "target": "produc